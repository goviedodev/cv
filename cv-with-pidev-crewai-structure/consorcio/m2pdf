#!/bin/bash

INPUT_FILE=${1:-"archivo.md"}
OUTPUT_FILE="${INPUT_FILE%.md}.pdf"

echo "Convirtiendo $INPUT_FILE a $OUTPUT_FILE..."

# Usamos librertine o dejavu si existen, pero forzamos una configuración
# que no dependa de fuentes del sistema externas al contenedor.
docker run --rm \
    -v "$(pwd):/data" \
    -u $(id -u):$(id -g) \
    pandoc/extra "$INPUT_FILE" -o "$OUTPUT_FILE" \
    --pdf-engine=xelatex \
    -V geometry:margin=2cm \
    -V mainfont="FreeSerif" \
    -V monofont="FreeMono"

if [ $? -eq 0 ]; then
    echo "¡Éxito! Archivo generado: $OUTPUT_FILE"
else
    # Si falla por fuentes, intentamos una versión ultra-compatible
    echo "Reintentando con configuración de emergencia..."
    docker run --rm \
        -v "$(pwd):/data" \
        -u $(id -u):$(id -g) \
        pandoc/extra "$INPUT_FILE" -o "$OUTPUT_FILE" \
        --pdf-engine=xelatex \
        -V geometry:margin=2cm
fi
